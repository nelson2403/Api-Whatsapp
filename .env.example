# ---------------------------------------------------------------------------
# Copie para .env.local e preencha. .env.local NAO vai pro git.
# ---------------------------------------------------------------------------

# Supabase ------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave service_role: ignora RLS por completo. Usada SO no webhook, que roda
# sem sessao de usuario. Nunca exponha com prefixo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Z-API ---------------------------------------------------------------------
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Segredo do webhook, gerado por voce. A URL vira:
#   https://seu-dominio/api/webhooks/zapi/<ESSE_VALOR>
# Gere com: openssl rand -hex 24
ZAPI_WEBHOOK_SECRET=

# IA (Groq) -----------------------------------------------------------------
# Sem essa chave a IA fica desligada e todo chamado escala direto pra humano.
GROQ_API_KEY=

# Modelos. Os defaults abaixo sao aplicados se as variaveis ficarem vazias.
GROQ_MODEL_RESPOSTA=llama-3.3-70b-versatile
GROQ_MODEL_CLASSIFICACAO=llama-3.1-8b-instant
GROQ_MODEL_VISAO=meta-llama/llama-4-scout-17b-16e-instruct

# App -----------------------------------------------------------------------
# URL publica do painel. Entra no link das mensagens de alerta.
NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app

# Protege a rota de cron que despacha alertas represados fora do horario.
# Gere com: openssl rand -hex 24
CRON_SECRET=
